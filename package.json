{
  "name": "gotchu",
  "version": "1.0.0",
  "description": "Break your slouching habit.",
  "scripts": {
    "dev": "bun run build && electrobun dev",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run dev\"",
    "hmr": "vite --port 5173",
    "build": "vite build && electrobun build",
    "build:prod": "vite build && electrobun build --channel prod",
    "start": "bun run dev"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.0",
    "clsx": "^2.1.1",
    "electrobun": "1.12.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
